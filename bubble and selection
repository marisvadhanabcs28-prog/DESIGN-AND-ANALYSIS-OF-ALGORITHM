#include"selhead.h"
void selection_sort(int A[],int n)
{
   int i,j,k,min,temp;
   for (i=0;i<=n-2;i++)
   {
      min=i;
      for(j=i+1;j<=n-1;j++)
      {
         if(A[min]>A[j])
            min=j;
      }
      temp=A[i];
      A[i]=A[min];
      A[min]=temp;
      printf("Pass no:%d\n",i+1);
      for (k=0;k<n;k++){
         printf("%d ",A[k]);
      }
      printf("\n");
   }
   printf("After sorting:");
   for(i=0;i<n;i++)
   {
      printf("%d ", A[i]);
   }
   printf("\n");
}


