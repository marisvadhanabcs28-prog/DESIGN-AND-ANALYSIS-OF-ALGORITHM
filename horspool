#include <iostream>

using namespace std;

void comparisonSortWithTable(int arr[], int n) {
    int count[n];
    int sortedArr[n];

    // Initialize counts to 0
    for (int i = 0; i < n; i++) count[i] = 0;

    cout << "\nPass #\tElement\t\tCurrent Count Array" << endl;
    cout << "--------------------------------------------------" << endl;
    for (int i = 0; i < n - 1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (arr[i] <= arr[j]) {
                count[j]++;
            } else {
                count[i]++;
            }
        }
        cout << (i + 1) << "\t" << arr[i] << "\t\t[ ";
        for (int k = 0; k < n; k++) {
            cout << count[k] << " ";
        }
        cout << "]" << endl;
    }
    for (int i = 0; i < n; i++) {
        sortedArr[count[i]] = arr[i];
    }

    for (int i = 0; i < n; i++) {
        arr[i] = sortedArr[i];
    }
}

int main() {
    int n;

    cout << "Enter the number of elements: ";
    cin >> n;

    int data[n];
    cout << "Enter " << n << " integers:" << endl;
    for (int i = 0; i < n; i++) {
        cout << "Element " << i + 1 << ": ";
        cin >> data[i];
    }

    comparisonSortWithTable(data, n);

    cout << "--------------------------------------------------" << endl;
    cout << "\nFinal Sorted Array: ";
    for (int i = 0; i < n; i++) {
        cout << data[i] << " ";
    }
    cout << endl;

    return 0;
}

