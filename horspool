#include <iostream>
#include <cstring>

using namespace std;

#define MAX_CHAR 26

void precomputeShiftTable(const char* pattern, int m, int shiftTable[]) {
    for (int i = 0; i < MAX_CHAR; i++) {
        shiftTable[i] = m;
    }
    for (int j = 0; j < m - 1; j++) {
        shiftTable[pattern[j] - 'a'] = m - 1 - j;
    }

    cout << "\n--- Shift Table ---" << endl;
    for (int j = 0; j < m - 1; j++) {
        cout << pattern[j] << " : " << shiftTable[pattern[j] - 'a'] << endl;
    }
    cout << "Others : " << m << endl;
}

int horspoolSearch(const char* text, const char* pattern) {
    int n = strlen(text);
    int m = strlen(pattern);

    if (m > n) return -1;

    int shiftTable[MAX_CHAR];
    precomputeShiftTable(pattern, m, shiftTable);

    cout << "\n--- Searching Steps ---" << endl;
    int i = m - 1;
    int step = 1;

    while (i < n) {
        cout << "Step " << step++ << ": Comparing pattern at index " << i - m + 1 << endl;
        cout << "  Text:    " << text << endl;

        for(int s=0; s < (i - m + 1); s++) cout << " ";
        cout << "  Pattern: " << pattern << endl;

        int k = 0;
        while (k < m && pattern[m - 1 - k] == text[i - k]) {
            k++;
        }

        if (k == m) {
            return i - m + 1;
        } else {
            int shift = shiftTable[text[i] - 'a'];
            cout << "  Mismatch! Character '" << text[i] << "' shifts pattern by " << shift << "\n" << endl;
            i += shift;
        }
    }
    return -1;
}

int main() {
    char text[500];
    char pattern[100];

    cout << "Enter the text (lowercase): ";
    cin.getline(text, 500);

    cout << "Enter the pattern (lowercase): ";
    cin.getline(pattern, 100);

    int result = horspoolSearch(text, pattern);

    if (result != -1) {
        cout << "\nFinal Result: Pattern found at index " << result << endl;
    } else {
        cout << "\nFinal Result: Pattern not found." << endl;
    }

    return 0;
}


