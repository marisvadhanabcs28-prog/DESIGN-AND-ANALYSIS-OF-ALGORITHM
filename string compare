#include "matchhead.h"

void trimNewline(char str[]) {
    str[strcspn(str, "\n")] = 0;
}

int main() {
    char text[100];
    char pattern[50];

    printf("--- Brute Force Visualizer ---\n");

    printf("Enter the Text: ");
    fgets(text, sizeof(text), stdin);
    trimNewline(text);

    printf("Enter the Pattern: ");
    fgets(pattern, sizeof(pattern), stdin);
    trimNewline(pattern);

    if (strlen(pattern) > strlen(text)) {
        printf("Error: Pattern cannot be longer than text.\n");
    } else {
        bruteForceMatch(text, pattern);
    }

    return 0;
}

