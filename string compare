#include "matchhead.h"

void bruteForceMatch(char text[], char pattern[]) {
    int n = strlen(text);
    int m = strlen(pattern);
    int comparisons = 0;
    int found = 0;

    printf("\nVisualizing Movement:\n");
    printf("TEXT: %s\n", text);
    printf("      ");
    int r;
    for(r = 0; r < n; r++) printf("%d", r % 10);
    printf("\n--------------------------------\n");
    int i,k;
    for (i = 0; i <= n - m; i++) {
        printf("[%02d] ", i);
        for (k= 0; k < i; k++) {
            printf(" ");
        }
        printf("%s", pattern);

        int j;
        for (j = 0; j < m; j++) {
            comparisons++;
            if (text[i + j] != pattern[j]) {
                break;
            }
        }

        if (j == m) {
            printf(" <-- MATCH\n");
            found = 1;
        } else {
            printf("\n");
        }
    }

    if (!found) printf("\nPattern not found.\n");
    printf("Total Comparisons: %d\n", comparisons);
}

