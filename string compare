#include <stdio.h>
#include "close.h"

int main() {
    int n;
    float minDist;

    printf("Enter number of points: ");
    scanf("%d", &n);

    float x[n], y[n];
    int i;
    for (i = 0; i < n; i++) {
        printf("Enter x and y coordinates of point %d: ", i + 1);
        scanf("%f %f", &x[i], &y[i]);
    }

    minDist = calculateDistance(x[0], y[0], x[1], y[1]);
    int p1 = 0, p2 = 1;
    int j;
    for (i = 0; i < n - 1; i++) {
        for (j = i + 1; j < n; j++) {
            float dist = calculateDistance(x[i], y[i], x[j], y[j]);
            if (dist < minDist) {
                minDist = dist;
                p1 = i;
                p2 = j;
            }
        }
    }

    printf("\nClosest Pair of Points:\n");
    printf("Point 1: (%.2f, %.2f)\n", x[p1], y[p1]);
    printf("Point 2: (%.2f, %.2f)\n", x[p2], y[p2]);
    printf("Minimum Distance = %.4f\n", minDist);

    return 0;
}

